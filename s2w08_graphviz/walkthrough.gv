digraph G {

	rankdir=LR;

	B [ label="Browser", fillcolor=green, style=filled];

	subgraph cluster_cloud {
	label="Cloud (AWS)";
	WS [ label="Web server" ];
	DB [ label="Database", shape=cylinder ];
	SQS [ label="SQS queue" ];
	}

	subgraph cluster_onsite {
	label="Onsite server room";
	AD [ label="AD server" ];
	}

	B -> WS [label="HTTPS"];
	WS -> DB;
	WS -> AD;
	WS -> SQS;

}