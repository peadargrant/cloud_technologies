digraph G {
	rankdir=LR;

	subgraph cluster_AWS {
	label="AWS";
	f [label="Lambda function"];
	subgraph cluster_otheraws {
	label="Other AWS services";
	db [label="DynamoDB table"];
	q [label="SQS queue"];
	s3 [label="S3 bucket"];
	}
	subgraph cluster_apigw {
	label="API gateway";
	api [label="API"];
	}
	}

	c0 [label="HTTP client"];

	c0 -> api;
	f -> db;
	f -> q;
	f -> s3;
	api -> f;

}