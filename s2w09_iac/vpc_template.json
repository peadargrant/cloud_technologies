{
    "Resources": {

	"LABVPC": {
	    "Type": "AWS::EC2::VPC",
	    "Properties": {
		"CidrBlock": "10.0.0.0/16",
		"Tags": [ { "Key": "Name", "Value": "LAB_VPC" } ]
	    }
	},
	
	"LAB1SN": {
	    "Type": "AWS::EC2::Subnet",
	    "Properties": {
		"AvailabilityZone": "eu-west-1a",
		"CidrBlock": "10.0.1.0/24",
		"MapPublicIpOnLaunch": true,
		"VpcId": { "Ref": "LABVPC" },
		"Tags": [
		    {
			"Key": "Name",
			"Value": "LAB_1_SN"
		    }
		]		
	    }
	},
	"LAB2SN": {
	    "Type": "AWS::EC2::Subnet",
	    "Properties": {
		"AvailabilityZone": "eu-west-1a",
		"CidrBlock": "10.0.2.0/24",
		"MapPublicIpOnLaunch": true,
		"VpcId": { "Ref": "LABVPC" },
		"Tags": [
		    {
			"Key": "Name",
			"Value": "LAB_2_SN"
		    }
		]
	    }
	},
	"LAB3SN": {
	    "Type": "AWS::EC2::Subnet",
	    "Properties": {
		"AvailabilityZone": "eu-west-1a",
		"CidrBlock": "10.0.3.0/24",
		"MapPublicIpOnLaunch": true,
		"VpcId": { "Ref": "LABVPC" },
		"Tags": [
		    {
			"Key": "Name",
			"Value": "LAB_3_SN"
		    }
		]
		
	    }
	},
	"LABIGW": {
	    "Type": "AWS::EC2::InternetGateway",
	    "Properties": {
		"Tags": [
		    {
			"Key": "Name",
			"Value": "LAB_IGW"
		    }
		]
	    }
	},
	"LABIGWAttach": {
	    "Type": "AWS::EC2::VPCGatewayAttachment",
	    "Properties": {
		"InternetGatewayId": { "Ref": "LABIGW" },
		"VpcId": { "Ref": "LABVPC" }
	    
	    }
	},
	
	"LABROUTE" : {
	    "Type" : "AWS::EC2::Route",
	    "DependsOn" : "LABIGW",
	    "Properties" : {
		"RouteTableId" : { "Ref" : "myRouteTable" },
		"DestinationCidrBlock" : "0.0.0.0/0",
		"GatewayId" : { "Ref" : "LABIGW" }
	    }
	}
	
    }
}
